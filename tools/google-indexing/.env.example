# Google Indexing API 批量提交工具 - 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ========== 文件路径配置 ==========
# Google 服务账号密钥文件
GOOGLE_KEY_FILE=service_account.json

# CSV 文件路径
CSV_FILE=Table.csv

# CSV 文件列名 (URL 所在的列名)
URL_COLUMN=URL

# ========== 代理配置 ==========
# 是否使用代理
USE_PROXY=true

# 代理服务器地址
PROXY_HOST=127.0.0.1

# 代理服务器端口
PROXY_PORT=7890

# ========== 提交配置 ==========
# 每批提交多少个 URL
BATCH_SIZE=10

# 批次间延迟(秒)
DELAY_BATCHES=5

# 请求间延迟(秒)
DELAY_REQUESTS=1

# ========== API 配置 ==========
# 最大重试次数
MAX_RETRIES=3

# 请求超时(秒)
REQUEST_TIMEOUT=30

# ========== 并发配置 ==========
# 最大并发工作线程数
MAX_WORKERS=3

# ========== 提交类型 ==========
# URL_UPDATED (更新) 或 URL_DELETED (删除)
SUBMISSION_TYPE=URL_UPDATED

# ========== 日志配置 ==========
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径 (留空则不记录到文件)
LOG_FILE=

# ========== 输出配置 ==========
# 输出目录
OUTPUT_DIR=results

# 跳过确认提示
NO_CONFIRM=false
